<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.TongzhiRecordDao">

    <resultMap type="com.cl.entity.TongzhiRecordEntity" id="tongzhiRecordMap">
        <result property="id" column="id"/>
        <result property="tongzhiId" column="tongzhiId"/>
        <result property="channelType" column="channelType"/>
        <result property="status" column="status"/>
        <result property="retryCount" column="retryCount"/>
        <result property="maxRetryCount" column="maxRetryCount"/>
        <result property="lastRetryTime" column="lastRetryTime"/>
        <result property="errorMessage" column="errorMessage"/>
        <result property="receiver" column="receiver"/>
        <result property="content" column="content"/>
        <result property="addtime" column="addtime"/>
        <result property="updatetime" column="updatetime"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.TongzhiRecordView" >

		SELECT  tongzhi_record.* FROM tongzhi_record  tongzhi_record 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.TongzhiRecordView" >
		SELECT * FROM tongzhi_record  tongzhi_record <where> 1=1 ${ew.sqlSegment}</where>
	</select>

	<select id="selectFailedRecords"
		resultType="com.cl.entity.TongzhiRecordEntity" >
		SELECT * FROM tongzhi_record 
		WHERE status = 'FAILED' 
		AND retryCount &lt; #{maxRetryCount}
		ORDER BY addtime ASC
	</select>

</mapper>
