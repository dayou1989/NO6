<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.TongzhijiluDao">

    <resultMap type="com.cl.entity.TongzhijiluEntity" id="tongzhijiluMap">
        <result property="tongzhibianhao" column="tongzhibianhao"/>
        <result property="yuyuebianhao" column="yuyuebianhao"/>
        <result property="yishengzhanghao" column="yishengzhanghao"/>
        <result property="dianhua" column="dianhua"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="shouji" column="shouji"/>
        <result property="jiuzhenshijian" column="jiuzhenshijian"/>
        <result property="tongzhineirong" column="tongzhineirong"/>
        <result property="fasongqudao" column="fasongqudao"/>
        <result property="fasongzhuangtai" column="fasongzhuangtai"/>
        <result property="shibaoyuanyin" column="shibaoyuanyin"/>
        <result property="chongshicishu" column="chongshicishu"/>
        <result property="zuidachongshi" column="zuidachongshi"/>
        <result property="xiacichongshishijian" column="xiacichongshishijian"/>
        <result property="fasongshijian" column="fasongshijian"/>
        <result property="beizhu" column="beizhu"/>
    </resultMap>

    <select id="selectListView"
        resultType="com.cl.entity.view.TongzhijiluView" >

        SELECT  tongzhijilu.* FROM tongzhijilu  tongzhijilu         
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>
    
    <select id="selectView"
        resultType="com.cl.entity.view.TongzhijiluView" >
        SELECT * FROM tongzhijilu  tongzhijilu <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectValue" resultType="map">
        SELECT ${params.xColumn}, sum(${params.yColumn}) total FROM tongzhijilu tongzhijilu
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map">
        <if test="params.timeStatType == '日'">
            SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM tongzhijilu tongzhijilu
            <where> 1=1 ${ew.sqlSegment}</where>
            group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test="params.timeStatType == '月'">
            SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM tongzhijilu tongzhijilu
            <where> 1=1 ${ew.sqlSegment}</where>
            group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test="params.timeStatType == '年'">
            SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM tongzhijilu tongzhijilu
            <where> 1=1 ${ew.sqlSegment}</where>
            group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map">
        SELECT ${params.column} , count(1) total FROM tongzhijilu tongzhijilu
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>

</mapper>
